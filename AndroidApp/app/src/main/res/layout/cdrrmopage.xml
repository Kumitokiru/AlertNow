<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/cdrrmoPageLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#224380">

    <LinearLayout
        android:id="@+id/nav_bar"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_alignParentTop="true"
        android:layout_marginTop="-3dp"
        android:background="@drawable/nav_bar2_border"
        android:orientation="vertical"
        android:padding="10dp"
        android:elevation="8dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="183dp">

            <ImageView
                android:id="@+id/alertlogo"
                android:layout_width="170dp"
                android:layout_height="40dp"
                android:contentDescription="AlertNow Logo"
                android:src="@drawable/alertlogo" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/cdrrmoLabel"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif"
                    android:gravity="start|center_vertical"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp" />

                <Button
                    android:id="@+id/layas"
                    android:layout_width="75dp"
                    android:layout_height="40dp"
                    android:background="@drawable/logout"
                    android:backgroundTint="#deeaee"
                    android:gravity="center"
                    android:textColor="#000000" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>




</RelativeLayout>